#include <stdio.h>

int main() {
    int correctPin = 1234;
    int pin, attempts = 3;
    float balance = 5000;
    int choice;
    float amount;

    while (attempts > 0) {
        printf("Enter ATM PIN: ");
        scanf("%d", &pin);

        if (pin == correctPin) {
            printf("\nLogin Successful!\n");

            do {
                printf("\n--- ATM MENU ---\n");
                printf("1. Check Balance\n");
                printf("2. Deposit\n");
                printf("3. Withdraw\n");
                printf("4. Exit\n");
                printf("Enter choice: ");
                scanf("%d", &choice);

                switch (choice) {
                    case 1:
                        printf("Balance: %.2f\n", balance);
                        break;

                    case 2:
                        printf("Enter amount to deposit: ");
                        scanf("%f", &amount);
                        balance += amount;
                        printf("Deposit successful!\n");
                        break;

                    case 3:
                        printf("Enter amount to withdraw: ");
                        scanf("%f", &amount);

                        if (amount <= balance) {
                            balance -= amount;
                            printf("Withdraw successful!\n");
                        } else {
                            printf("Insufficient balance!\n");
                        }
                        break;

                    case 4:
                        printf("Thank you for using ATM.\n");
                        break;

                    default:
                        printf("Invalid choice!\n");
                }

            } while (choice != 4);

            return 0;
        } else {
            attempts--;
            printf("Wrong PIN! Attempts left: %d\n", attempts);
        }
    }

    printf("Card Blocked!\n");

    return 0;
}